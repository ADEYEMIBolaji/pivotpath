# Copy this file to .env.local and fill in your values.

# ── AI models ──────────────────────────────────────────────────────────────────
# Anthropic Claude (default — required unless using Grok exclusively)
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok (optional — enables Grok model toggle in the onboarding wizard)
# Get a key at: https://console.x.ai/
XAI_API_KEY=xai-...

# ── Postgres (required for production / Vercel) ────────────────────────────────
# Free options: Neon (neon.tech), Supabase, Railway
# Without this, the app falls back to file-based storage (dev only)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Migration secret (required for /api/migrate) ──────────────────────────────
# Any random string — keep it secret
MIGRATE_SECRET=change-me-to-a-random-string

# ── Job board APIs (all optional — falls back to mock data if not set) ─────────
REED_API_KEY=your-reed-api-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
# LinkedIn and Otta require partner approval — leave blank to use mock data
LINKEDIN_API_TOKEN=
OTTA_API_KEY=

# ── Auth (NextAuth / Auth.js) ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-base64-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — enables "Continue with Google")
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Payments (Paddle — Merchant of Record) ─────────────────────────────────────
# Dashboard → Developer Tools. Use Sandbox keys first, then switch to live.
# Environment: "sandbox" while testing, "production" when live
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Client-side token (safe to expose) — Authentication → Client-side tokens
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx
# Server API key (secret) — Authentication → API keys
PADDLE_API_KEY=
# Webhook signing secret — Notifications → your destination
PADDLE_WEBHOOK_SECRET=
# Price IDs from Catalog → Products → Prices (pri_...). One per tier + billing cycle.
# Pivot tier (£19/mo · £99/yr) — recurring prices, no trial (the Free tier is the hook).
NEXT_PUBLIC_PADDLE_PRICE_PIVOT_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRICE_PIVOT_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxxxxxx
# Accelerate tier (£39/mo · £179/yr)
NEXT_PUBLIC_PADDLE_PRICE_ACCELERATE_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRICE_ACCELERATE_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Dev helpers ────────────────────────────────────────────────────────────────
# Skip HEAD-checking job URLs (speeds up local dev)
SKIP_LINK_VERIFICATION=true
