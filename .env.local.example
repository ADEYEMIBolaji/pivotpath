# Copy this file to .env.local and fill in your values.

# ── Anthropic (required for analysis pipeline) ─────────────────────────────────
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Postgres (required for production / Vercel) ────────────────────────────────
# Free options: Neon (neon.tech), Supabase, Railway
# Without this, the app falls back to file-based storage (dev only)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Migration secret (required for /api/migrate) ──────────────────────────────
# Any random string — keep it secret
MIGRATE_SECRET=change-me-to-a-random-string

# ── Job board APIs (all optional — falls back to mock data if not set) ─────────
REED_API_KEY=your-reed-api-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
# LinkedIn and Otta require partner approval — leave blank to use mock data
LINKEDIN_API_TOKEN=
OTTA_API_KEY=

# ── Dev helpers ────────────────────────────────────────────────────────────────
# Skip HEAD-checking job URLs (speeds up local dev)
SKIP_LINK_VERIFICATION=true
