# Copy this file to .env.local and fill in your values.

# ── AI models ──────────────────────────────────────────────────────────────────
# Anthropic Claude (default — required unless using Grok exclusively)
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok (optional — enables Grok model toggle in the onboarding wizard)
# Get a key at: https://console.x.ai/
XAI_API_KEY=xai-...

# ── Postgres (required for production / Vercel) ────────────────────────────────
# Free options: Neon (neon.tech), Supabase, Railway
# Without this, the app falls back to file-based storage (dev only)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Migration secret (required for /api/migrate) ──────────────────────────────
# Any random string — keep it secret
MIGRATE_SECRET=change-me-to-a-random-string

# ── Job board APIs (all optional — falls back to mock data if not set) ─────────
REED_API_KEY=your-reed-api-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
# LinkedIn and Otta require partner approval — leave blank to use mock data
LINKEDIN_API_TOKEN=
OTTA_API_KEY=

# ── Auth (NextAuth / Auth.js) ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-base64-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — enables "Continue with Google")
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Payments (Lemon Squeezy — Merchant of Record) ──────────────────────────────
# Checkouts are created server-side, so nothing here is NEXT_PUBLIC.
# API key — Settings → API (starts "eyJ...")
LEMONSQUEEZY_API_KEY=
# Store id (the number in Settings → Stores, or the dashboard URL)
LEMONSQUEEZY_STORE_ID=
# Webhook signing secret — Settings → Webhooks → your endpoint
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant ids from Products → your subscription → Variants. One per tier + cycle.
# Pivot tier (£19/mo · £99/yr) — recurring, no trial (the Free tier is the hook).
LEMONSQUEEZY_VARIANT_PIVOT_MONTHLY=
LEMONSQUEEZY_VARIANT_PIVOT_ANNUAL=
# Accelerate tier (£39/mo · £179/yr)
LEMONSQUEEZY_VARIANT_ACCELERATE_MONTHLY=
LEMONSQUEEZY_VARIANT_ACCELERATE_ANNUAL=

# ── Dev helpers ────────────────────────────────────────────────────────────────
# Skip HEAD-checking job URLs (speeds up local dev)
SKIP_LINK_VERIFICATION=true
